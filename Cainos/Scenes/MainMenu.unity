  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "HOW TO PLAY\r\n\r\nYour goal is to survive disaster cycles by keeping
    the world sustainable.\r\n\r\nEach cycle:\r\n\u2022 A timer runs down\r\n\u2022
    Your sustainability bar must stay above zero\r\n\r\nWhat you can do:\r\n\u2022
    Plant trees to increase sustainability\r\n\u2022 Collect resources like food,
    wood, and saplings\r\n\u2022 Build structures to generate resources\r\n\u2022
    Some buildings help, others harm sustainability\r\n\r\nDisasters:\r\n\u2022 At
    the end of each cycle, a disaster happens\r\n\u2022 Your performance is evaluated\r\n\u2022
    The next cycle begins\r\n\r\nYou lose if:\r\n\u2022 Sustainability reaches 0\r\n\r\nStrategy
    tips:\r\n\u2022 Do not overuse resources\r\n\u2022 Balance growth and sustainability\r\n\u2022
    Prepare before each disaster"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5302535af1044152a457ed104f1f4b91, type: 2}
